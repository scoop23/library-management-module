rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Books and Categories: any signed-in library staff can read; only
    // Administrator/Librarian roles (checked via a custom claim) can write.
    match /Books/{bookId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.token.role in ['Administrator', 'Librarian'];
    }

    match /BookCopies/{copyId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.token.role in ['Administrator', 'Librarian'];
    }

    match /Categories/{categoryId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.token.role == 'Administrator';
    }

    // Deny everything else by default until the remaining modules
    // (Borrowing, Reservations, Fines, Settings, AuditLogs) are integrated.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
